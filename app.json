{
  "expo": {
    "name": "MimamoriBridge",
    "slug": "mimamori-bridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "mimamori-bridge",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.miki-studio.mimamori-bridge",
            "infoPlist": {
        "NSHealthShareUsageDescription": "家族の安否確認のために歩数データを共有します",
        "NSHealthUpdateUsageDescription": "ヘルスデータの更新権限は使用しません",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "CFBundleLocalizations": [
          "ja",
          "en"
        ],
        "CFBundleDevelopmentRegion": "ja"
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [
          "health-records"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "net.mikistudio.mimamoribrige",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4CAF50"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2aac1616-bfd1-48ee-976b-84f50961534c"
      },
      "router": {}
    },
    "owner": "mikiriceshop"
  }
}
